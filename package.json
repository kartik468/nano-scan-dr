    "copy:nano-scan-dr:site": "rm -rf /Users/kartikr/Desktop/git/site-development/kartik/github-pages/kartik468.github.io/nanoscandr/* && cp -r dist/nano-scan-dr/browser/. /Users/kartikr/Desktop/git/site-development/kartik/github-pages/kartik468.github.io/nano-scan-dr/",
